# Copy to ".env" in the project root and set real values. Docker Compose reads ".env" automatically.
# Do not commit ".env".

# PostgreSQL (db service; car-service / notification-service JDBC use the same credentials via compose)
POSTGRES_DB=dynamic_car_sharing_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# JWT signing (car-service)
JWT_SECRET=

# Grafana admin login
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=
