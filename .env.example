# Copy to .env in the repo root; do not commit .env.

POSTGRES_DB=dynamic_car_sharing_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
# Base64-encoded HMAC key shared by api-gateway, user-service, booking-service, dispute-service, car-service (must match everywhere JWT is validated).
JWT_SECRET=NDM0YjVmNjM1MTY0NWE3NDc3Mzg3YTMzNjE1MTQxNTg0NTUxNDg0ZjU0N2IzYjRmNmE1YjdhNmE0ZDQxNjM1Mg==
# Same value on services that call user/booking internal APIs or expose internal routes (booking).
USER_SERVICE_INTERNAL_API_KEY=change-me-for-non-local
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=
