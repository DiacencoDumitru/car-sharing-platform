<configuration scan="true">

    <springProperty scope="context" name="appName"  source="spring.application.name" defaultValue="app"/>
    <springProperty scope="context" name="profiles" source="spring.profiles.active"   defaultValue="default"/>
    <springProperty scope="context" name="instance" source="eureka.instance.instance-id" defaultValue="${HOSTNAME:-unknown}"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"service":"${appName}","profile":"${profiles}","instance":"${instance}"}</customFields>
        </encoder>
    </appender>

    <appender name="LOGSTASH" class="net.logstash.logback.appender.LogstashTcpSocketAppender">
        <destination>logstash:5044</destination>

        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"service":"${appName}","profile":"${profiles}","instance":"${instance}"}</customFields>
            <jsonGeneratorDecorator class="net.logstash.logback.mask.ValueMaskingJsonGeneratorDecorator">
                <maskPatterns>
                    <pattern>"(authorization|password|token|secret)"\s*:\s*".*?"</pattern>
                    <pattern>"jwt"\s*:\s*".*?"</pattern>
                </maskPatterns>
            </jsonGeneratorDecorator>
        </encoder>
    </appender>

    <logger name="com.dynamiccarsharing" level="DEBUG"/>
    <logger name="org.springframework.cloud.client.discovery" level="INFO"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="LOGSTASH"/>
    </root>
</configuration>
